---
import { siteConfig } from "../../config";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

export function getStaticPaths() {
  return siteConfig.projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{project.name} | {siteConfig.name}</title>
  </head>
  <body class="bg-white text-gray-900">
    <Header />

    <main class="min-h-screen">
      <!-- Hero Section -->
      <section class="py-16 sm:py-20 md:py-24 lg:py-32 px-4 sm:px-6 md:px-8 lg:px-12">
        <div class="max-w-4xl mx-auto">
          <a
            href="/#projects"
            class="inline-flex items-center gap-2 text-sm sm:text-base text-gray-600 hover:text-gray-900 transition-colors mb-8"
          >
            <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Volver a Proyectos
          </a>

          <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 mb-4">
            {project.name}
          </h1>

          {project.skills && project.skills.length > 0 && (
            <div class="flex flex-wrap gap-2 sm:gap-3 mb-8">
              {project.skills.map((skill) => (
                <span
                  class="px-3 sm:px-4 py-1.5 sm:py-2 bg-gray-900 text-white rounded-lg text-sm sm:text-base font-medium"
                >
                  {skill}
                </span>
              ))}
            </div>
          )}

          {project.link && (
            <a
              href={project.link}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-white font-medium transition-all duration-300 hover:opacity-90"
              style={`background-color: ${siteConfig.accentColor}`}
            >
              Ver Proyecto
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17" />
              </svg>
            </a>
          )}
        </div>
      </section>

      <!-- Content Section -->
      <section class="px-4 sm:px-6 md:px-8 lg:px-12 pb-16 sm:pb-20 md:pb-24 lg:pb-32">
        <div class="max-w-4xl mx-auto">
          <div class="prose prose-lg max-w-none">
            <slot />
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>